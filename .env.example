# ── API-Sicherheit ────────────────────────────────────────────────────────────
# Beliebiger geheimer Schlüssel – wird im Header X-API-Key erwartet
# Leer lassen = kein Schutz (nur für lokale Tests)
API_KEY=dein-geheimer-api-key

# ── Freenet ───────────────────────────────────────────────────────────────────
FREENET_USERNAME=deine@email.de
FREENET_PASSWORD=deinPasswort

# ── NetAachen ─────────────────────────────────────────────────────────────────
NETAACHEN_USERNAME=deine@email.de
NETAACHEN_PASSWORD=deinPasswort

# ── Lexware ───────────────────────────────────────────────────────────────────
LEXWARE_USERNAME=deine@email.de
LEXWARE_PASSWORD=deinPasswort

# ── Verhalten ─────────────────────────────────────────────────────────────────
# true  = Browser läuft im Hintergrund (Produktionsbetrieb)
# false = Browser sichtbar via VNC (Debug-Modus)
HEADLESS=true

# DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO

# ── Pfade (Standardwerte passen zu docker-compose.yml) ───────────────────────
DOWNLOAD_DIR=/downloads
